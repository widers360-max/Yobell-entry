generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Company {
  id             String  @id @default(cuid())
  name           String
  logoUrl        String?
  welcomeMessage String?
  active         Boolean @default(true)
  staff          Staff[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Staff {
  id                 String  @id @default(cuid())
  companyId          String
  company            Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  name               String
  department         String
  role               String
  email              String?
  phone              String?
  notificationMethod String  @default("dashboard")
  active             Boolean @default(true)
  visits             Visit[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Visit {
  id             String    @id @default(cuid())
  visitorName    String
  visitorCompany String?
  visitorPhone   String?
  purpose        String?
  visitorType    String
  hostStaffId    String
  hostStaff      Staff     @relation(fields: [hostStaffId], references: [id])
  status         String    @default("pending")
  photoData      String?
  createdAt      DateTime  @default(now())
  respondedAt    DateTime?
  updatedAt      DateTime  @updatedAt
}

model KioskSetting {
  id                 String  @id @default("default")
  languageDefault    String  @default("ja")
  retentionDays      Int     @default(30)
  privacyNotice      String  @default("入力された情報は受付対応および来訪記録のために利用されます。")
  fallbackMessage    String  @default("担当者が応答できません。お手数ですがお電話またはメールでご連絡ください。")
  brandName          String  @default("YOBELL")
  tagline            String  @default("内線電話のないオフィス受付")
  logoUrl            String?
  welcomeMessage     String  @default("ご来社ありがとうございます")
  heroImageUrl       String?
  heroVideoUrl       String?
  companyDisplayName String  @default("株式会社YOBELL")
  heroTitle          String  @default("ようこそ、株式会社YOBELLへ")
  heroSubtitle       String  @default("快適なオフィス環境を、すべての人に。")
  primaryColor       String  @default("#1a2b4b")
  accentColor        String  @default("#c9a227")
}

model VisitorCard {
  id        String  @id @default(cuid())
  typeKey   String  @unique
  title     String
  subtitle  String
  iconKey   String  @default("Users")
  sortOrder Int     @default(0)
  active    Boolean @default(true)
}
